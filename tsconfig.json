{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "dist-ts",
    "rootDir": ".",
    "allowJs": true,
    "checkJs": false,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": [
    "main.ts",
    "preload.ts",
    "dialog-senha-preload.ts",
    "services/**/*.ts",
    "public/**/*.js",
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "dist-ts",
    "coverage",
    "test",
    "build",
    "public/fontawesome"
  ]
}
