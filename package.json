{
  "name": "financas",
  "version": "0.1.6",
  "description": "Sistema de Finanças Pessoais",
  "main": "dist-ts/main.js",
  "author": "Alan Silveira",
  "private": true,
  "homepage": "https://github.com/alanjsil/Ferus360",
  "repository": {
    "type": "git",
    "url": "https://github.com/alanjsil/Ferus360.git"
  },
  "scripts": {
    "start": "npm run build:ts && electron .",
    "build:ts": "rimraf dist-ts && tsc",
    "lint": "eslint .",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.config.integrado.js",
    "cover": "npx vitest run --coverage",
    "build": "electron-builder --publish never",
    "build_mac": "electron-builder --mac --publish never",
    "build:trial": "node -e \"require('fs').writeFileSync('trial-config.json',JSON.stringify({dias:15})+'\\n')\" && electron-builder --publish never",
    "test:playwright": "npm run build:ts && playwright test",
    "check": "npm run lint && npm run test",
    "release": "electron-builder --publish always",
    "release:win": "electron-builder --win --publish always",
    "release:mac": "electron-builder --mac --publish always"
  },
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  },
  "build": {
    "appId": "com.deltaAutomacoes.financas",
    "productName": "FinancasPessoais",
    "artifactName": "financas-${version}.${ext}",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "license": "LICENSE.md",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.png"
    },
    "files": [
      "src/",
      "main.js",
      "dist-ts/",
      "preload.js",
      "package.json",
      "public/**/*",
      "services/**/*",
      "trial-config.json",
      "dialog-senha-preload.js"
    ],
    "extraFiles": [
      {
        "from": "LICENSE.md",
        "to": "."
      },
      {
        "from": "README.md",
        "to": "."
      }
    ],
    "forceCodeSigning": false
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.90.1",
    "chart.js": "^4.4.8",
    "electron-updater": "^6.8.9"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@emnapi/core": "^1.10.0",
    "@emnapi/runtime": "^1.10.0",
    "@eslint/js": "^10.0.1",
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@playwright/test": "^1.61.0",
    "@types/node": "^26.0.0",
    "@vitest/coverage-v8": "^4.1.6",
    "canvas": "^3.2.3",
    "dotenv": "^17.4.2",
    "electron": "^39.8.10",
    "electron-builder": "^26.0.12",
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "rimraf": "^6.1.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "allowScripts": {
    "electron-winstaller@5.4.0": true,
    "electron@39.8.10": true
  }
}
